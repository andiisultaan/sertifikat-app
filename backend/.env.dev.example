APP_NAME="Sertifikat UKK"
APP_ENV=local
APP_KEY=        # jalankan: php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
